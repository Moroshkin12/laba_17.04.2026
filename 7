#7. Найти площадь кольца, у которого внутренний радиус равен R₁, а внешний — R₂ (R₂ > R₁). R₁, R₂ могут быть
# вещественными числами. В качестве значения числа π использовать константу 3.1415.
# Организовать диалог с пользователем следующим образом:
#Вычисление площади кольца.
#Введите исходные данные:
#Внутренний радиус (см) → 12
#Внешний радиус (см) → 30
#Площадь кольца: 2375.04 кв. см.

print("Вычисление площади кольца.\nВведите исходные данные:")


def get_positive_float(prompt):
    """
    Запрашивает у пользователя положительное вещественное число.

    Returns:
        float: Введённое пользователем положительное вещественное число.
    """
    while True:
        try:
            value = float(input(prompt))
            if value <= 0:
                print("Ошибка! Радиус должен быть положительным числом. Попробуйте ещё раз.")
                continue
            return value
        except ValueError:
            print("Ошибка! Введите корректное число. Попробуйте ещё раз.")


inner_radius = get_positive_float("Внутренний радиус (см) -> ")
outer_radius = get_positive_float("Внешний радиус (см) -> ")

# Проверка, что внешний радиус больше внутреннего
while outer_radius <= inner_radius:
    print("Ошибка! Внешний радиус должен быть больше внутреннего. Попробуйте ещё раз.")
    outer_radius = get_positive_float("Внешний радиус (см) -> ")

# Расчёт площади
PI = 3.14159
area_outer = PI * (outer_radius ** 2)
area_inner = PI * (inner_radius ** 2)
ring_area = area_outer - area_inner

print("Площадь кольца:", round(ring_area, 2), "кв. см.")


