#While18. Дано целое число N (> 0). Используя операции деления нацело и взятия остатка
# от деления, найти количество и сумму его цифр.

number = input("Введите число: ")

if number.isdigit():
    number = int(number)
    digit_count = 0
    digit_sum = 0

    while number > 0:
        digit_count += 1
        digit_sum += number % 10
        number = number // 10

    print("Количество цифр =", digit_count)
    print("Сумма цифр =", digit_sum)
else:
    print("Ошибка! Введите целое положительное число.")


# примеры : aaa, 234.234, -234, 0 0.
